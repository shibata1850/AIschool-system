# AI推論基盤の設定（未決事項#3: 【仮】Claude API。抽象化レイヤーで切替可能）
# AI_PROVIDER: mock | claude | local
AI_PROVIDER=mock

# Claude API を使う場合のみ設定（キーはコミット禁止 — CLAUDE.md 2章）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ローカルLLM（校内GPUサーバー）を使う場合のみ設定
LOCAL_LLM_BASE_URL=

# Canvas LMS（OSS版）ステージング接続（docs/Canvasステージング構築手順.md）
# 未設定の間は参照実装のインメモリストアで動作する
CANVAS_BASE_URL=
CANVAS_API_TOKEN=

# S4 Jupyter演習の接続先（未設定の間は準備中の案内を表示。docs/JupyterHub構築手順.md）
JUPYTERHUB_URL=
# GPUサーバー停止時に案内する静的教材のURL（任意・F2例外3）
JUPYTER_FALLBACK_URL=

# 開発・デモ・E2Eでロールを role Cookie で切り替える場合のみ 1
# （本番＝LTI運用では設定しない。設定漏れ時にCookieで管理者昇格されるのを防ぐ）
DEV_COOKIE_ROLES=

# デモ用の授業風景データ（授業中の教室16席）を表示する場合のみ 1
DEMO_RICH_SEED=

# LTI 1.3 連携（Canvasの開発者キー登録後に設定 — docs/LTI連携手順.md）
# 未設定の間はロールCookie（開発・デモ用）で動作する
LTI_ISSUER=
LTI_CLIENT_ID=
LTI_AUTH_URL=
LTI_JWKS_URL=
LTI_TOKEN_URL=
LTI_TOOL_URL=
LTI_DEPLOYMENT_ID=
# 本人確認セッションCookieの署名鍵（十分に長いランダム値。コミット禁止）
LTI_SESSION_SECRET=
# ツール側の署名鍵（LTI Advantageサービス用・任意。PKCS8 PEM。コミット禁止）
LTI_PRIVATE_KEY=
LTI_KEY_ID=
