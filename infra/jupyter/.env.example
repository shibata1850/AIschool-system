# JupyterHub 構築用の環境変数（infra/jupyter/docker-compose.yml が読む）。
# このファイルを infra/jupyter/.env にコピーして値を入れる。.env はコミットしない。
#
# ▼ 下の4つは「同じCanvasを指す」ので、カスタム層の .env と同じ値をそのまま入れる
LTI_ISSUER=
LTI_AUTH_URL=
LTI_JWKS_URL=
LTI_TOKEN_URL=
#
# ▼ JupyterHub専用のCanvas開発者キーの client_id（カスタム層とは別キー）
#   Canvasで JupyterHub 用の開発者キーを作ると発行される（README 手順2）
JUPYTER_LTI_CLIENT_ID=
#
# ▼ 受講生コンテナ（既定でOK。9月のGPUサーバーでは専用イメージに差し替え）
SINGLEUSER_IMAGE=quay.io/jupyter/base-notebook:latest
# 1コア1GBのデモ機では小さめに（同時起動は1〜数名に絞る）。GPU機では引き上げる
SINGLEUSER_MEM_LIMIT=512M
